	template<typename N_t= std::uintmax_t,
	         N_t N=0, N_t M=1>
	N_t return_addition{ //important for "return 0 if N+M is 1" else return N+M

		if((N+M)==1) {
			return 0;
		}
		else {
			return N+M;
		}

	}
template<template<std::uintmax_t, std::uintmax_t, std::intmax_t, typename N_t_, N_t_, bool> class bc, std:uintmax_t instance, std::uintmax_t sub_instance, typename N_t, N_t N, bool s, std::uintmax_t b>
	consteval void register_power_of_b() {
		N_t_ smallest_perfect_power=1; //smallest_perfect_power is the smallest_perfect_power bigger than N
		for(smallest_perfect_power>N; smallest_perfect_power*=b) {
			bc<instance, sub_instance, N_t,smallest_perfect_power, s> dummy{};
		}
	}
	template< std::uintmax_t instance,//instance is purely to avoid writing the same thing many times
	          std::uintmax_t obj_instance,//zero if you just want a number (in that case instance would be 0 or 1)
	          std::intmax_t minus_by=0,//zero if signing in an object and N to find the last N object. The
	          typename N_t= std::uintmax_t,
	          N_t N=0, bool search_or_asked= false>
	struct sequential_count {
		//will also be used to represent enumeurators now, hence tried to make this super efficient (LogbN) efficieny, the speed increases in relativity to the greatness of the value object/number that you are trying to find
		template< std::array<unsigned char, sizeof(N_t)> multipy_by= {1, 0}, std::uintmax_t b_= b>
		consteval static N_t get_num() {
			//complete but probably needs debugging/double checking a million times to be trusted 100%:
			if(exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N, multipy_by>()), true>::template does()) {
				//check if the current exists: current_N*current_multiply_by
				if(!exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N, multipy_by*b_>()), true>::template does()) {
					//check if the current_N*Next_multiply_by_exist(multipy_by*b_) does not exist
					if(exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N, multipy_by*b_>())-b_, true>::template does()) {
						//check if the current_N*Next_multiply_by_exist(multipy_by*b_)-b_ does exists
						return sequential_count<instance, obj_instance, minus_by, N_t, (return_addition<N, multipy_by>()), true>::template get_num<1,2>();
					}
					else if(exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N, multipy_by*b_>())-1, true>::template does()) {
						if(exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N, multipy_by*b_>()), false>::template does()) {
							//the extra check if to make sure that the empty (multipy_by*b_) slot found was registered by sequential_count instead of register_power_of_b.
							return (N*multipy_by*b_)-minus_by; //found a power of b_ ( lucky isnt it :), like dont you get it that the odds of finding out while counting or finding object is really low? )
						}
						else {
							//finds out (N*multipy_by)+(the whole process overagain) but not in the process that you would expect:
							return sequential_count<instance, obj_instance, minus_by, N_t, (return_addition<N, multipy_by>()), true, minus_by>::template get_num<1, b_>();
						}

					}
				}

				else {
					//going even deeper
					return sequential_count<instance, obj_instance, minus_by, N_t, (return_addition<N, multipy_by>()), true, minus_by>::template get_num< multipy_by*b, b_>();
				}
			}
			else {
				register_power_of_b<sequential_count, instance, obj_instance, N_t, (N*multipy_by), false, b_>();
				return (N*multipy_by)-minus_by;
			}
		}

	};

