constexpr bool error_for_lack_of_precision_integers_b= sizeof(std::uintmax_t)> sizeof(unsigned char);
template<typename T>
consteval std::size_t find_index_where_number_ends(T& arg) {
	//finds the index+1, where the element at index is zero and has all numbers to its left as zero
	unsigned char* raw_arg= reinterpret_cast<unsigned char*>(&(arg.obj_stored));
	std::size_t where_number_ends= 0;
	std::size_t size_of_data=sizeof(T);
	for(std::size_t i = 0; i < size_of_data; i++) {
		where_number_ends++;
		if(raw_arg[i]!=0) {
			where_number_ends=0;//we start counting from zero
		}
	}
	return size_of_data-where_number_ends;
}
template<std::size_t size_of_data>
consteval std::size_t find_index_where_number_ends(std::array<unsigned char, size_of_data>& N) {
	//finds the index+1, where the element at index is zero and has all numbers to its left as zero
	std::size_t where_number_ends= 0;
	for(std::size_t i = 0; i < size_of_data; i++) {
		where_number_ends++;
		if(N[i]!=0) {
			where_number_ends=1;//we start counting from zero
		}
	}
	return size_of_data-where_number_ends;
}
template<std::size_t size_of_data>
consteval std::array<unsigned char, size_of_data> operator*(std::array<unsigned char, size_of_data> arg, std::uintmax_t N) {
	static_assert(error_for_lack_of_precision_integers_b, "no two digit char found!!!!!");
	std::size_t i=0;
	std::uintmax_t carry=0;
	for(; i<size_of_data; i++) {
		std::uintmax_t result=( static_cast<std::uintmax_t>(arg[i]) * N )+carry;
		arg[i]= static_cast<unsigned char>(result);//taking advantage of the fact that narrowing will exclude the bits on the left
		carry= result>>CHAR_BIT;
	}
	return arg;

}
consteval char* multiply(char *arg, std::size_t size_of_array, unsigned char N) {
	static_assert(error_for_lack_of_precision_integers_b, "no two digit char found!!!!!");
	std::size_t i=0;
	std::uintmax_t carry=0;
	for(; i<size_of_array; i++) {
		std::uintmax_t result=( static_cast<std::uintmax_t>(arg[i]) * std::uintmax_t(N) )+carry;
		arg[i]= static_cast<unsigned char>(result);//taking advantage of the fact that narrowing will exclude the bits on the left
		carry= result>>CHAR_BIT;
	}
	return arg;

}
template<typename T>
struct raw_object { //object in integer form (think of it like hexdump of an object)
	//todo:
	//here for me mathematic is just looking at classic techniques and copying them for base sizeof(char), so read the code while keeping that in mind.
	T obj_stored;
	constexpr static std::size_t size_of_data= sizeof(T);
	consteval raw_object(T& a): obj_stored{a} {
		//I know code is messy but didnt know a better way, sorry
	}
	consteval raw_object(raw_object& a): obj_stored{a.obj_stored} {

	}


	consteval raw_object operator+(std::array<unsigned char, size_of_data>& N) {
		raw_object temp;
		bool carry=false;
		unsigned char* raw_object= reinterpret_cast<unsigned char*>(&(temp.obj_stored));
		for(std::size_t i=0; i<size_of_data; i++) {
			unsigned char result=  N[i] + raw_object[i] + carry;
			carry= ( result < N[i] ) ? true : false;
			raw_object[i] = result;
		}
		return temp;
	}
	consteval raw_object operator-(std::uintmax_t N) {
		static_assert(error_for_lack_of_precision_integers_b, "no two digit char found!!!!!");
		raw_object temp=*this;
		unsigned char* temp_array= reinterpret_cast<unsigned char*>(&(temp.obj_stored));
		constexpr std::size_t size_chosen= std::min(sizeof(std::uintmax_t), sizeof(raw_object));
		std::array<unsigned char, size_chosen> array_rhs{};
		for(int i= 0; i< size_chosen; i++) {
			array_rhs[i]= N>>(CHAR_BIT*i);//converting N into array_form
		}
		for(int i= 0; i< size_chosen; i++) {
			if(temp_array[i]<array_rhs[i]) {
				static_assert((i+1)!=size_chosen, "underflow about was about to be caused by righthand side being larger than the left hand side in a substraction operation.");
				temp_array[i+1]--;
				std::uintmax_t temp_array[i]=((1<<CHAR_BIT)+temp_array[i])-array_rhs[i];
			}
		}
		return temp;
	}


	consteval raw_object multiply(char *N, std::size_t size_of_array) {
		static_assert(size_of_array==size_of_data, "size mismatch");
		constexpr std::size_t where_this_ends=find_index_where_number_ends<T,N>(*(this->obj_stored));
		std::array<raw_object, where_this_ends> result{0};
		unsigned char* temp_array= reinterpret_cast<unsigned char*>(*(this->obj_stored));// i named it temp_array to follow that personal naming convention that i introduced in this source file

		for(std::size_t i=0; i<where_this_ends; i++) {
			result[i]= multiply(N, size_of_array, temp_array[i]);
			std::size_t where_result_ends= find_index_where_number_ends(result[i]);
			for(; where_result_ends!=0; where_result_ends--) {
				result[0]+= result[where_result_ends];
			}

		}
		switch(where_this_ends) {

		case 2:

			for(std::size_t i=1; i<where_this_ends; i++) {

				result[0]+=result[i];

			}
			return result[0];
		case 1:
			return result[0];


		case 0:
			result *this;

		}
	}
	consteval raw_object operator*(std::array<unsigned char, size_of_data>& array) {
		return multiply(array.data(), size_of_data);

	}
	consteval raw_object operator*(raw_object arg) {
		return multiply(reinterpret_cast<char*>(&(arg.obj_stored)), size_of_data);
	}
	consteval bool operator==(raw_object& arg) {
		unsigned char* temp_array_lhs= reinterpret_cast<char*>(&obj_stored);
		unsigned char* temp_array_rhs= reinterpret_cast<char*>(&(arg.obj_stored));
		for(int i=0; i<size_of_data; i++) {
			if(temp_array_lhs[i]!=temp_array_rhs[i]) {
				return false;
			}
		}
		return true;
	}
	consteval bool operator>(raw_object& arg) {
		unsigned char* temp_array_lhs= reinterpret_cast<char*>(&obj_stored);
		unsigned char* temp_array_rhs= reinterpret_cast<char*>(&(arg.obj_stored));
		bool result= true;//dummy value
		for(int i=0; i<size_of_data; i++) {
			if(temp_array_lhs[i]>temp_array_rhs[i]) {
				result= true;
			}
			else {
				result= false;
			}
		}
		return result;
	}

};
struct Not_base {
	//no aliases like Enum_t or Base_t are necessary here!
	constexpr Not_base() {}
	template<typename T>
	constexpr Not_base(T&& a) {} //just a place holder
	constexpr Not_base(std::uintmax_t)
	{

	}
};
template<typename T, typename Base= Not_base>
//Base must be another wrapper object
struct Enum_wrapper: Base {
	using Enum_t=T;
	using Base_t= Base;
	Enum_t enumerator;
	bool is_initialized;
	constexpr Enum_wrapper() {}
	constexpr Enum_wrapper(Enum_t a):
		enumerator{a}, is_initialized{true} {}
	template<typename Other_Enum_t>
    requires(std::is_scoped_enum_v<Other_Enum_t>)
	constexpr Enum_wrapper(Other_Enum_t a): Base{a}, enumerator{}, is_initialized{false} {}
	constexpr Enum_wrapper(std::uintmax_t a): Base{0}, enumerator{static_cast<Enum_t>(a)},
		is_initialized{false} {

	}

	//One could optionally (to make it even better) append/add:
	/*
	        using enum Enum_t;
	            using Base;
	                Or Anything equavulent to the two lines above
	                    */
};
template <typename Enum_wrapper,  Enum_wrapper obj,template<typename T, T obj_nested> typename correct_enum>
consteval auto potential_base() {
	using potential_base= typename Enum_wrapper::Base_t;
	if constexpr (!obj.is_initialized) {
		if constexpr (std::is_same_v<potential_base,Not_base>) {
			return;
		}
		else {
			return correct_enum<potential_base, potential_base{obj}> {};
		}
	}
	else {
		return;
	}
}
template<typename Enum_wrapper, Enum_wrapper obj>
struct correct_enum {
	using potential_base_t=
	    decltype(
	        potential_base<Enum_wrapper, obj, correct_enum>()
	    );
	using enum_t=
	    std::conditional_t<
	    obj.is_initialized,
	    typename Enum_wrapper::Enum_t,
	    typename potential_base_t::enum_t
	    >;
	static constexpr enum_t enum_v = obj.is_initialized ? obj.enumerator : potential_base_t::enum_v;
};


constexpr std::uintmax_t minus_by_global= 1;
template<typename N_t= std::uintmax_t, typename T,
         N_t N, T M>
consteval N_t return_addition() { //important for "return 0 if N+M is 1" else return N+M

	return (N+M)-minus_by_global;

}
template<std::size_t size_of_array, unsigned char first_element_initializer>
consteval std::array<unsigned char, size_of_array> give_init_container_with_first_elem_and_zeros() {
    //*for array speciliazation*
	std::array<unsigned char, size_of_array> array_to_initialize{};
	array_to_initialize.fill(0);
	array_to_initialize[0]= first_element_initializer;
	return array_to_initialize;
}
	template<template<std::uintmax_t, std::uintmax_t, std::uintmax_t, typename N_t_, N_t_, bool> class bc, std::uintmax_t instance, std::uintmax_t sub_instance, std::uintmax_t m, typename N_t, N_t N, bool s>
	struct exist {
		//million credits to
		//https://www.lukas-barth.net/blog/checking-if-specialized/
		//for saving me here:
		template<typename exist_if_exist= decltype(std::declval<bc<instance, sub_instance, m, N_t, N,s>>().~bc<instance, sub_instance, m, N_t, N, s>())>
		bool static consteval does() {
			return true;
		}
		bool static consteval does() {
            if(!m){
                bc<instance, sub_instance, m, N_t, N,s> dummy{}; 
            }
			return false;
		}
	};
    template<typename N_t, unsigned char init_first_digit>
    struct config_of_screws_in_the_engine{
        constexpr static std::size_t size_of_raw_data_array=init_first_digit;
        using type= std::array<unsigned char, size_of_raw_data_array>;
        consteval static type get_init(){
            return give_init_container_with_first_elem_and_zeros<size_of_raw_data_array, init_first_digit>();
        }
    };
    template<std::integral N_t, unsigned char init_first_digit>
    struct config_of_screws_in_the_engine<N_t, init_first_digit>{
        consteval static N_t get_init(){
            return init_first_digit;
        }
        using type= N_t;
    };
	template<template<std::uintmax_t, std::uintmax_t, std::uintmax_t, typename N_t_, N_t_, bool> class bc, std::uintmax_t instance, std::uintmax_t sub_instance, std::uintmax_t minus_by, typename N_t, N_t N, bool s, std::uintmax_t b, N_t multiply_by>
	consteval void register_power_of_b() {
	if(multiply_by<N){
    bc<instance, sub_instance, minus_by, N_t,multiply_by-minus_by_global, s> dummy{};
    register_power_of_b<bc, instance, sub_instance, minus_by, N_t, N, s, b, multiply_by*b>();
    }
    
	}
template<std::uintmax_t domain=0>
struct generator_and_reader_infrustructor {
    //usually the namespace domain that you should number using "domain" should be the global namespace (to avoid linker issues)
    //but if the C++ standard provides an interface to get a unique id with the combination of a filename with a namespace name.
	//the extra domain argument is to localize it across multiple namespaces 
	constexpr static unsigned char b= 10;//THE B IN logbN and should not be 1! (I couldve done somthing to allow it to be one), in which the complexity is just linear N when it is one and it would take if statement to handle that case of it being 1, but I realized that would cost compile time overhead

	template< std::uintmax_t instance,//instance is purely to avoid writing the same thing many times
	          std::uintmax_t obj_instance,//zero if you just want a number (in that case instance would be 0 or 1)
	          std::uintmax_t minus_by=0,//zero if signing in an object and N to find the last N object. The
	          typename N_t= std::uintmax_t,
	          N_t N=0, bool search_or_asked= false>
	struct sequential_count {
        using multiply_by_t=config_of_screws_in_the_engine<N_t, 1>;
		//will also be used to represent enumeurators now, hence tried to make this super efficient (LogbN) efficieny, the speed increases in relativity to the greatness of the value object/number that you are trying to find
		template< multiply_by_t::type plus_with= multiply_by_t::get_init(),
		          std::uintmax_t b_ =  b >
		consteval static N_t get_num() {
        	//(1.0)complete but probably needs debugging/double checking a million times to be trusted 100%:
			if(exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N_t,typename multiply_by_t::type,N, plus_with>()), true>::template does() ||
               exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N_t,typename multiply_by_t::type,N, plus_with>()), false>::template does()) {
				//(1.1)check if the current exists: current_N*current_multiply_by and if the 
				if(!exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N_t,typename multiply_by_t::type,N, plus_with*b_>()), true>::template does()) {
					//(1.2)check if the current_N*Next_multiply_by_exist(plus_with*b_) does not exist
					if(exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N_t,typename multiply_by_t::type,N, plus_with*b_>())-b_, true>::template does()) {
						//(1.3)check if the current_N*Next_multiply_by_exist(plus_with*b_)-b_ does exists
						sequential_count<instance, obj_instance, minus_by, N_t, N, false> dummy{};//useful for the condition: "(1.5)".
						return sequential_count<instance, obj_instance, minus_by, N_t, (return_addition<N_t,typename multiply_by_t::type,N, plus_with*b_>())-b_, false>::template get_num<1,2>();
					}
					else if(exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N_t,typename multiply_by_t::type,N, plus_with*b_>()), true>::template does()) {
						//(1.4)
                        if(exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N_t,typename multiply_by_t::type,N, plus_with*b_>()), false>::template does()) {
							//(1.5)the extra check if to make sure that the empty (plus_with*b_) slot found was registered by sequential_count instead of register_power_of_b.
                            if(!minus_by){
                                register_power_of_b<sequential_count, instance, obj_instance, minus_by, N_t, (N*plus_with), true, b_, N_t{1}>();
                                sequential_count<instance, obj_instance, minus_by, N_t, N, false> dummy{};//useful for the condition: "(1.5)".
                                return (return_addition<N_t,typename multiply_by_t::type,N, plus_with*b_>()); //found a power of b_ ( lucky isnt it :), like dont you get it that the odds of finding out while counting or finding object is really low? )
                            }
						}
						else {
							//finds out (N*plus_with)+(the whole process overagain) but not in the process that you would expect:
							sequential_count<instance, obj_instance, minus_by, N_t, N, false> dummy{};//useful for the condition: "(1.5)".
							return sequential_count<instance, obj_instance, minus_by, N_t, (return_addition<N_t,typename multiply_by_t::type, N, plus_with*config_of_screws_in_the_engine<N_t, 1>::get_init()>()), false>::template get_num<1, b_>();
						}

					}
				}

				else {
					//going even deeper
                    sequential_count<instance, obj_instance, minus_by, N_t, N, false> dummy{};//useful for the condition: "(1.5)".
					return sequential_count<instance, obj_instance, minus_by, N_t, N, false>::template get_num< plus_with*b, b_>();
				}
			}
			else if(!exist<sequential_count, instance, obj_instance, minus_by, N_t, (return_addition<N_t,typename multiply_by_t::type,N, plus_with>()), false>::template does()) {
                if(!minus_by){
                    register_power_of_b<sequential_count, instance, obj_instance, minus_by, N_t, (N*plus_with), true, b_, N_t{1}>();
                }
                sequential_count<instance, obj_instance, minus_by, N_t, N, false> dummy{};//useful for the condition: "(1.5)".
                return return_addition<N_t,typename multiply_by_t::type,N, plus_with>();

			}
		}

	};
	template< std::uintmax_t instance,
	          std::uintmax_t obj_instance,
	          std::uintmax_t minus_by=0,
	          typename N_t= std::uintmax_t,
	          N_t N=0, bool search_or_asked= false>
    consteval static N_t get_num(){
    constexpr auto return_val=
    sequential_count<instance, obj_instance, minus_by, N_t, N, false>::template get_num();
    return return_val;
    }
};

