template< std::uint8_t instance,//instance is purely to avoid writing the same thing many times
std::uintmax_t N=0, bool search_or_asked= false>
struct sequential_count {
    //will also be used to represent enumeurators now, hence tried to make this super efficient
	template< std::uintmax_t multipy_by=1, std::uintmax_t b_= b>
    consteval static std::uintmax_t get_num() {

		if(exist<sequential_count, instance, (N*multipy_by), true>::template does<multipy_by, b_>()) {
			if(exist<sequential_count, instance, (N*multipy_by)-b_, true>::template does<multipy_by, b_>()){
                return sequential_count<instance, N, true>::template get_num<1,2>();
            }
            else{
            return sequential_count<instance, (N*multipy_by*b), true>::template get_num< multipy_by*b, b_>();
            }
		}
		else {
			return N;
		}
	}

};

